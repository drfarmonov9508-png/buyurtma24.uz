    "@nestjs/websockets": "^10.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/cache-manager": "^2.2.1",
    "@nestjs/config": "^3.2.0",
    "@nestjs/bull": "^10.1.1",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-yet": "^5.1.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2",
    "qrcode": "^1.5.3",
    "bull": "^4.12.2",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.1",
    "dayjs": "^1.11.10",
    "xlsx": "^0.18.5",
    "pdfkit": "^0.15.0",
    "socket.io": "^4.7.4"
