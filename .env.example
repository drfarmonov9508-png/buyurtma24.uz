# ================================================
# Buyurtma24.uz — Environment Configuration
# ================================================

# App
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=buyurtma24
DB_USER=buyurtma24_user
DB_PASSWORD=strongpassword123

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispassword123

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# Cors
CORS_ORIGINS=http://localhost:3001,https://admin.buyurtma24.uz,https://superadmin.buyurtma24.uz,https://client.buyurtma24.uz

# SuperAdmin seed credentials
SUPERADMIN_EMAIL=superadmin@buyurtma24.uz
SUPERADMIN_PASSWORD=SuperAdmin@2024!

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# QR Code base URL
QR_BASE_URL=https://client.buyurtma24.uz/menu
